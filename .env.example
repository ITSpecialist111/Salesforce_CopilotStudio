# Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# --- Salesforce Connection ---
# Options: User_Password, OAuth_2_0_Client_Credentials, Salesforce_CLI
SALESFORCE_CONNECTION_TYPE=User_Password

# For User_Password auth:
SALESFORCE_USERNAME=your-username@salesforce.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_TOKEN=your-security-token

# For OAuth 2.0 Client Credentials auth (recommended for production):
# SALESFORCE_CONNECTION_TYPE=OAuth_2_0_Client_Credentials
# SALESFORCE_CLIENT_ID=your-connected-app-client-id
# SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret

# Salesforce login URL (use https://test.salesforce.com for sandboxes)
SALESFORCE_INSTANCE_URL=https://login.salesforce.com

# --- Server ---
PORT=3000

# --- Optional: API Key Authentication ---
# Set this to require an API key in the X-API-Key header
# API_KEY=your-secure-api-key-here
